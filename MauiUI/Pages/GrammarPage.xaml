<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TianGongKaiWu.Pages.GrammarPage"
             Title="字字珠玑"
             BackgroundColor="{StaticResource BgDark}">
    <VerticalStackLayout Padding="15">
        <Label Text="📖 天工字典" FontSize="24" TextColor="{StaticResource Secondary}" FontAttributes="Bold"/>
        <ListView x:Name="GrammarListView" BackgroundColor="Transparent">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <HorizontalStackLayout Padding="10">
                            <Label Text="{Binding Key}" TextColor="#FAB387" FontAttributes="Bold"/>
                            <Label Text=" → " TextColor="Gray"/>
                            <Label Text="{Binding Value}" TextColor="#A6E3A1"/>
                        </HorizontalStackLayout>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
            <Button Text="📤 导出" BackgroundColor="#2196F3" TextColor="White" CornerRadius="20" Clicked="OnExport"/>
            <Button Text="📥 导入" BackgroundColor="#9C27B0" TextColor="White" CornerRadius="20" Clicked="OnImport"/>
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>
