<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TianGongKaiWu.Pages.NvWaPage"
             Title="女娲·造化"
             BackgroundColor="#1A0A2E">
    <Grid RowDefinitions="Auto,*,Auto" Padding="15">
        <VerticalStackLayout Grid.Row="0" HorizontalOptions="Center" Margin="0,10">
            <Label Text="🌸 女娲 · 抟土造人" FontSize="26" TextColor="#F48FB1" FontAttributes="Bold" HorizontalOptions="Center"/>
            <Label Text="纯原生运行，万物生长" FontSize="14" TextColor="#B39DDB" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <Frame Grid.Row="1" CornerRadius="12" BackgroundColor="#2D1B4E" Padding="5">
            <Editor x:Name="PlaygroundEditor" Placeholder="输入拼音代码..." TextColor="White" BackgroundColor="Transparent" HeightRequest="220" FontFamily="monospace" FontSize="14"/>
        </Frame>

        <VerticalStackLayout Grid.Row="2" Spacing="10">
            <Button x:Name="RunButton" Text="▶ 造化万物" BackgroundColor="{StaticResource AccentNvwa}" TextColor="White" CornerRadius="20" Clicked="OnRun"/>
            <Frame BackgroundColor="#1E1E2E" CornerRadius="10" Padding="10" HasShadow="True">
                <Label x:Name="RunOutput" Text="等待创造..." TextColor="#CDD6F4" FontFamily="monospace"/>
            </Frame>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
