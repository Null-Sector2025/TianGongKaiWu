<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TianGongKaiWu.Pages.FileManagerPage"
             Title="万物档案"
             BackgroundColor="{StaticResource BgDark}">
    <VerticalStackLayout Padding="15">
        <Label Text="📂 造化项目" FontSize="24" TextColor="{StaticResource AccentPangu}" FontAttributes="Bold"/>
        <ListView x:Name="ProjectListView" ItemTapped="OnProjectSelected" BackgroundColor="Transparent">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextCell Text="{Binding Name}" Detail="{Binding Path}" TextColor="White" DetailColor="Gray"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Button Text="➕ 新开天地" BackgroundColor="#4CAF50" TextColor="White" CornerRadius="20" Clicked="OnNewProject"/>
    </VerticalStackLayout>
</ContentPage>
