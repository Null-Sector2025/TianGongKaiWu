<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TianGongKaiWu.Pages.PanGuPage"
             Title="盘古·造物"
             BackgroundColor="{StaticResource BgDark}">
    <Grid RowDefinitions="Auto,*,Auto,*,Auto" Padding="15" ColumnDefinitions="*,*">
        <!-- 标题区域 -->
        <VerticalStackLayout Grid.Row="0" HorizontalOptions="Center" Margin="0,10">
            <Label Text="🐉 盘古 · 造化神工" FontSize="26" TextColor="{StaticResource AccentPangu}" FontAttributes="Bold" HorizontalOptions="Center"/>
            <Label Text="全语言转换，NDK 加持" FontSize="14" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- 代码输入区 -->
        <Frame Grid.Row="1" CornerRadius="12" BackgroundColor="{StaticResource Surface}" Padding="5" HasShadow="True">
            <Editor x:Name="CodeEditor" Placeholder="输入拼音代码..." TextColor="White" BackgroundColor="Transparent" HeightRequest="220" FontFamily="monospace" FontSize="14"/>
        </Frame>

        <!-- 转换按钮组 -->
        <FlexLayout Grid.Row="2" Wrap="Wrap" JustifyContent="Center" Margin="0,10">
            <Button Text="⚡ Java" BackgroundColor="#FF9800" TextColor="White" CornerRadius="20" Margin="5" Clicked="OnConvertJava"/>
            <Button Text="🎯 C#" BackgroundColor="#9C27B0" TextColor="White" CornerRadius="20" Margin="5" Clicked="OnConvertCSharp"/>
            <Button Text="🐍 Python" BackgroundColor="#2196F3" TextColor="White" CornerRadius="20" Margin="5" Clicked="OnConvertPython"/>
            <Button Text="🌐 JS" BackgroundColor="#FFEB3B" TextColor="Black" CornerRadius="20" Margin="5" Clicked="OnConvertJS"/>
            <Button Text="🧪 执行" BackgroundColor="#4CAF50" TextColor="White" CornerRadius="20" Margin="5" Clicked="OnExecuteCode"/>
        </FlexLayout>

        <!-- 输出区 -->
        <Frame Grid.Row="3" CornerRadius="12" BackgroundColor="#313244" Padding="5" HasShadow="True">
            <Editor x:Name="OutputEditor" IsReadOnly="True" TextColor="#CDD6F4" BackgroundColor="Transparent" HeightRequest="180" FontFamily="monospace" FontSize="14"/>
        </Frame>

        <!-- 底部操作 -->
        <HorizontalStackLayout Grid.Row="4" Spacing="15" HorizontalOptions="Center" Margin="0,5">
            <Button Text="📂 打开" BackgroundColor="#607D8B" TextColor="White" CornerRadius="20" Clicked="OnOpenProject"/>
            <Button Text="💾 保存" BackgroundColor="#4CAF50" TextColor="White" CornerRadius="20" Clicked="OnSaveProject"/>
        </HorizontalStackLayout>
    </Grid>
</ContentPage>
